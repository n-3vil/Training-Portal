rules_version = '2';

// ============================================================================
//  SOTI Training Portal — Firestore security rules
//  Paste this ENTIRE file into: Firebase console -> Firestore Database ->
//  Rules tab -> replace everything -> Publish.
//
//  IMPORTANT: the ADMIN_EMAILS list below must match the one in
//  firebase-config.js. Edit the email(s) in the isAdmin() function.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- EDIT THIS LIST to match your instructor email(s) ---
    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email in ['emmanuelnevill@gmail.com'];
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Cohort settings + training plan: everyone signed in can read, admin writes.
    match /config/{doc} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Homework assignments (no grades stored here): read by all, write by admin.
    match /homework/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Task assignments (no per-student status here): read by all, write by admin.
    match /tasks/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Student profiles and their private data.
    match /students/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      // A student may create ONLY their own profile, starting as pending with no progress.
      allow create: if isSelf(uid)
        && request.resource.data.status == 'pending'
        && request.resource.data.completedModules.size() == 0;
      allow update, delete: if isAdmin();

      // Grades & feedback: the student can read their own; only admin can write.
      match /grades/{hwId} {
        allow read: if isSelf(uid) || isAdmin();
        allow write: if isAdmin();
      }

      // Task progress: the student can read and update their own; admin too.
      match /taskstatus/{taskId} {
        allow read: if isSelf(uid) || isAdmin();
        allow write: if isSelf(uid) || isAdmin();
      }
    }
  }
}
